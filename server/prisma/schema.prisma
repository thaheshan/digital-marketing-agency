generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  content_manager
  client
}

enum UserStatus {
  pending_verification
  active
  suspended
  deactivated
}

enum CampaignStatus {
  draft
  live
  paused
  completed
  cancelled
}

enum EnquiryStatus {
  new
  contacted
  qualified
  converted
  closed_lost
}

enum LeadTemperature {
  hot
  warm
  cold
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ContentStatus {
  draft
  published
  archived
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum MessageThreadStatus {
  open
  resolved
}

enum ChatbotSessionStatus {
  active
  closed
  escalated_to_human
}

enum DripEmailStatus {
  queued
  sent
  failed
  cancelled
}

enum GoalStatus {
  not_started
  on_track
  exceeding
  needs_attention
  missed
}

enum ReportType {
  monthly_performance
  quarterly
  ad_hoc
  audit
}

enum DocumentType {
  contract
  proposal
  brief
  asset
  other
}

enum Platform {
  Facebook
  Instagram
  Google
  LinkedIn
  TikTok
}

enum AdType {
  image
  video
  carousel
  story
}

enum MediaType {
  image
  video
  document
  creative
}

enum ScoreCategory {
  behaviour
  form
}

enum Portal {
  client
  staff
  system
}

model User {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String      @unique @db.VarChar(255)
  passwordHash      String      @map("password_hash") @db.VarChar(255)
  role              Role
  firstName         String      @map("first_name") @db.VarChar(100)
  lastName          String      @map("last_name") @db.VarChar(100)
  phone             String?     @db.VarChar(50)
  profilePhotoUrl   String?     @map("profile_photo_url") @db.VarChar(500)
  status            UserStatus  @default(pending_verification)
  emailVerified     Boolean     @default(false) @map("email_verified")
  twoFaEnabled      Boolean     @default(false) @map("two_fa_enabled")
  twoFaSecret       String?     @map("two_fa_secret") @db.VarChar(255)
  failedLoginCount  Int         @default(0) @map("failed_login_count")
  lockedUntil       DateTime?   @map("locked_until") @db.Timestamptz
  lastLoginAt       DateTime?   @map("last_login_at") @db.Timestamptz
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  staffProfile          StaffProfile?
  staffPermissions      StaffPermissions?
  clientProfile         ClientProfile?
  passwordResetTokens   PasswordResetToken[]
  emailVerifyTokens     EmailVerificationToken[]
  sessions              Session[]
  assignedEnquiries     Enquiry[]          @relation("AssignedEnquiries")
  convertedEnquiries    Enquiry[]          @relation("ConvertedEnquiries")
  clientCampaigns       Campaign[]         @relation("ClientCampaigns")
  createdCampaigns      Campaign[]         @relation("CreatedCampaigns")
  managedClients        ClientProfile[]    @relation("AccountManager")
  reports               Report[]           @relation("GeneratedReports")
  clientReports         Report[]           @relation("ClientReports")
  clientDocuments       ClientDocument[]   @relation("ClientDocuments")
  uploadedDocuments     ClientDocument[]   @relation("UploadedDocuments")
  clientInvoices        Invoice[]          @relation("ClientInvoices")
  createdInvoices       Invoice[]          @relation("CreatedInvoices")
  messageThreads        MessageThread[]
  sentMessages          Message[]
  notifications         Notification[]
  portfolioItems        PortfolioItem[]    @relation("CreatedPortfolio")
  services              Service[]          @relation("CreatedServices")
  blogPosts             BlogPost[]
  mediaUploads          MediaLibrary[]
  approvedTestimonials  Testimonial[]      @relation("ApprovedTestimonials")
  enquiryNotes          EnquiryNote[]
  enquiryStatusChanges  EnquiryStatusHistory[]
  aiGenerations         AiDescriptionGeneration[] @relation("TriggeredGenerations")
  activityLogs          ActivityLog[]
  updatedSettings       SystemSetting[]
  chatbotKnowledge      ChatbotKnowledgeBase[]
  contentScoreHistory   ContentScoreHistory[]
  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model StaffProfile {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  department          String?  @db.VarChar(100)
  jobTitle            String?  @map("job_title") @db.VarChar(100)
  bio                 String?  @db.Text
  displayOnAboutPage  Boolean  @default(false) @map("display_on_about_page")
  linkedinUrl         String?  @map("linkedin_url") @db.VarChar(500)
  twitterUrl          String?  @map("twitter_url") @db.VarChar(500)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("staff_profiles")
}

model StaffPermissions {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  canManagePortfolio    Boolean  @default(false) @map("can_manage_portfolio")
  canManageBlog         Boolean  @default(false) @map("can_manage_blog")
  canManageTestimonials Boolean  @default(false) @map("can_manage_testimonials")
  canViewEnquiries      Boolean  @default(false) @map("can_view_enquiries")
  canManageEnquiries    Boolean  @default(false) @map("can_manage_enquiries")
  canViewClients        Boolean  @default(false) @map("can_view_clients")
  canManageClients      Boolean  @default(false) @map("can_manage_clients")
  canViewAnalytics      Boolean  @default(false) @map("can_view_analytics")
  canManageServices     Boolean  @default(false) @map("can_manage_services")
  canManageChatbot      Boolean  @default(false) @map("can_manage_chatbot")
  canManageTeam         Boolean  @default(false) @map("can_manage_team")
  canManageSettings     Boolean  @default(false) @map("can_manage_settings")
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("staff_permissions")
}

model ClientProfile {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  companyName         String    @map("company_name") @db.VarChar(255)
  industry            String?   @db.VarChar(100)
  companySize         String?   @map("company_size") @db.VarChar(50)
  websiteUrl          String?   @map("website_url") @db.VarChar(500)
  accountManagerId    String?   @map("account_manager_id") @db.Uuid
  contractStartDate   DateTime? @map("contract_start_date") @db.Date
  contractEndDate     DateTime? @map("contract_end_date") @db.Date
  monthlyBudgetPence  Int?      @map("monthly_budget_pence")
  currency            String    @default("GBP") @db.Char(3)
  portalAccess        Boolean   @default(true) @map("portal_access")
  notes               String?   @db.Text
  referralSource      String?   @map("referral_source") @db.VarChar(100)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  user           User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountManager User? @relation("AccountManager", fields: [accountManagerId], references: [id])
  @@map("client_profiles")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  otpCode    String   @map("otp_code") @db.Char(6)
  linkToken  String   @map("link_token") @db.VarChar(255)
  attempts   Int      @default(0)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("email_verification_tokens")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  portal    String   @db.VarChar(20)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Service {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                  String   @unique @db.VarChar(100)
  name                  String   @db.VarChar(200)
  tagline               String?  @db.VarChar(300)
  description           String?  @db.Text
  iconName              String?  @map("icon_name") @db.VarChar(100)
  iconGradientStart     String?  @map("icon_gradient_start") @db.Char(6)
  iconGradientEnd       String?  @map("icon_gradient_end") @db.Char(6)
  priceFromPence        Int?     @map("price_from_pence")
  priceBasicPence       Int?     @map("price_basic_pence")
  priceProPence         Int?     @map("price_pro_pence")
  priceEnterprisePence  Int?     @map("price_enterprise_pence")
  featuresBasic         Json?    @map("features_basic")
  featuresPro           Json?    @map("features_pro")
  featuresEnterprise    Json?    @map("features_enterprise")
  sortOrder             Int      @default(0) @map("sort_order")
  isPublished           Boolean  @default(false) @map("is_published")
  projectsCompleted     Int      @default(0) @map("projects_completed")
  avgRoiPercent         Int      @default(0) @map("avg_roi_percent")
  createdBy             String?  @map("created_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz
  creator        User?             @relation("CreatedServices", fields: [createdBy], references: [id])
  portfolioItems PortfolioItem[]
  campaigns      Campaign[]
  pricingItems   PricingQuoteItem[]
  @@map("services")
}

model PortfolioItem {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String        @unique @db.VarChar(150)
  title               String        @db.VarChar(300)
  clientName          String        @map("client_name") @db.VarChar(200)
  clientIndustry      String?       @map("client_industry") @db.VarChar(100)
  serviceId           String?       @map("service_id") @db.Uuid
  serviceCategory     String?       @map("service_category") @db.VarChar(100)
  description         String?       @db.Text
  challengeText       String?       @map("challenge_text") @db.Text
  solutionText        String?       @map("solution_text") @db.Text
  campaignStartDate   DateTime?     @map("campaign_start_date") @db.Date
  campaignEndDate     DateTime?     @map("campaign_end_date") @db.Date
  channelsUsed        Json?         @map("channels_used")
  aiGeneratedOption1  String?       @map("ai_generated_option_1") @db.Text
  aiGeneratedOption2  String?       @map("ai_generated_option_2") @db.Text
  aiGeneratedOption3  String?       @map("ai_generated_option_3") @db.Text
  selectedAiOption    Int?          @map("selected_ai_option") @db.SmallInt
  contentScore        Int?          @map("content_score") @db.SmallInt
  status              ContentStatus @default(draft)
  isFeatured          Boolean       @default(false) @map("is_featured")
  sortOrder           Int           @default(0) @map("sort_order")
  viewsCount          Int           @default(0) @map("views_count")
  createdBy           String?       @map("created_by") @db.Uuid
  publishedAt         DateTime?     @map("published_at") @db.Timestamptz
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  service             Service?                  @relation(fields: [serviceId], references: [id])
  creator             User?                     @relation("CreatedPortfolio", fields: [createdBy], references: [id])
  images              PortfolioImage[]
  metrics             PortfolioMetric[]
  testimonials        Testimonial[]
  aiGenerations       AiDescriptionGeneration[]
  contentScoreRecord  ContentScore?             @relation("PortfolioContentScore")
  contentScoreHistory ContentScoreHistory[]
  @@index([status])
  @@index([serviceCategory])
  @@index([isFeatured])
  @@map("portfolio_items")
}

model PortfolioImage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioItemId String   @map("portfolio_item_id") @db.Uuid
  url             String   @db.VarChar(500)
  altText         String?  @map("alt_text") @db.VarChar(300)
  isFeatured      Boolean  @default(false) @map("is_featured")
  sortOrder       Int      @default(0) @map("sort_order")
  widthPx         Int?     @map("width_px")
  heightPx        Int?     @map("height_px")
  fileSizeBytes   Int?     @map("file_size_bytes")
  uploadedAt      DateTime @default(now()) @map("uploaded_at") @db.Timestamptz
  portfolioItem PortfolioItem @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)
  @@map("portfolio_images")
}

model PortfolioMetric {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioItemId String  @map("portfolio_item_id") @db.Uuid
  metricLabel     String  @map("metric_label") @db.VarChar(100)
  metricValue     String  @map("metric_value") @db.VarChar(100)
  metricPrefix    String? @map("metric_prefix") @db.VarChar(20)
  metricSuffix    String? @map("metric_suffix") @db.VarChar(20)
  sortOrder       Int     @default(0) @map("sort_order")
  portfolioItem PortfolioItem @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)
  @@map("portfolio_metrics")
}

model Testimonial {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientName      String         @map("client_name") @db.VarChar(200)
  clientTitle     String?        @map("client_title") @db.VarChar(200)
  clientCompany   String?        @map("client_company") @db.VarChar(200)
  clientPhotoUrl  String?        @map("client_photo_url") @db.VarChar(500)
  reviewText      String         @map("review_text") @db.Text
  rating          Int            @db.SmallInt
  platform        String?        @db.VarChar(50)
  portfolioItemId String?        @map("portfolio_item_id") @db.Uuid
  servicesUsed    Json?          @map("services_used")
  isVerified      Boolean        @default(false) @map("is_verified")
  isFeatured      Boolean        @default(false) @map("is_featured")
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  approvedBy      String?        @map("approved_by") @db.Uuid
  videoUrl        String?        @map("video_url") @db.VarChar(500)
  sortOrder       Int            @default(0) @map("sort_order")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  portfolioItem PortfolioItem? @relation(fields: [portfolioItemId], references: [id])
  approver      User?          @relation("ApprovedTestimonials", fields: [approvedBy], references: [id])
  @@map("testimonials")
}

model BlogPost {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String        @unique @db.VarChar(200)
  title            String        @db.VarChar(400)
  excerpt          String?       @db.VarChar(500)
  content          String?       @db.Text
  featuredImageUrl String?       @map("featured_image_url") @db.VarChar(500)
  authorId         String?       @map("author_id") @db.Uuid
  status           ContentStatus @default(draft)
  contentScore     Int?          @map("content_score") @db.SmallInt
  seoTitle         String?       @map("seo_title") @db.VarChar(300)
  seoDescription   String?       @map("seo_description") @db.VarChar(400)
  readTimeMinutes  Int?          @map("read_time_minutes") @db.SmallInt
  viewsCount       Int           @default(0) @map("views_count")
  publishedAt      DateTime?     @map("published_at") @db.Timestamptz
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  author             User?               @relation(fields: [authorId], references: [id])
  categories         BlogPostCategory[]
  contentScoreRecord ContentScore?       @relation("BlogContentScore")
  scoreHistory       ContentScoreHistory[]
  @@map("blog_posts")
}

model BlogCategory {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String @unique @db.VarChar(100)
  slug     String @unique @db.VarChar(100)
  colorHex String @map("color_hex") @db.Char(6)
  posts BlogPostCategory[]
  @@map("blog_categories")
}

model BlogPostCategory {
  postId     String @map("post_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([postId, categoryId])
  @@map("blog_post_categories")
}

model MediaLibrary {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename      String    @db.VarChar(300)
  url           String    @db.VarChar(500)
  thumbnailUrl  String?   @map("thumbnail_url") @db.VarChar(500)
  mimeType      String?   @map("mime_type") @db.VarChar(100)
  fileSizeBytes Int?      @map("file_size_bytes")
  mediaType     MediaType @map("media_type")
  altText       String?   @map("alt_text") @db.VarChar(300)
  uploadedBy    String?   @map("uploaded_by") @db.Uuid
  uploadedAt    DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz
  uploader User? @relation(fields: [uploadedBy], references: [id])
  @@map("media_library")
}

model SiteVisitor {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken         String   @unique @map("session_token") @db.VarChar(255)
  ipAddress            String?  @map("ip_address") @db.VarChar(45)
  userAgent            String?  @map("user_agent") @db.Text
  referrerUrl          String?  @map("referrer_url") @db.VarChar(1000)
  utmSource            String?  @map("utm_source") @db.VarChar(200)
  utmMedium            String?  @map("utm_medium") @db.VarChar(200)
  utmCampaign          String?  @map("utm_campaign") @db.VarChar(200)
  firstSeenAt          DateTime @default(now()) @map("first_seen_at") @db.Timestamptz
  lastSeenAt           DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  totalPageViews       Int      @default(0) @map("total_page_views")
  totalSessions        Int      @default(1) @map("total_sessions")
  convertedToEnquiry   Boolean  @default(false) @map("converted_to_enquiry")
  enquiryId            String?  @map("enquiry_id") @db.Uuid
  events            VisitorEvent[]
  enquiry           Enquiry?          @relation(fields: [enquiryId], references: [id])
  chatbotSessions   ChatbotSession[]
  roiResults        RoiCalculatorResult[]
  auditResults      AuditToolResult[]
  pricingQuotes     PricingQuote[]
  @@map("site_visitors")
}

model VisitorEvent {
  id                  BigInt   @id @default(autoincrement())
  visitorId           String   @map("visitor_id") @db.Uuid
  eventType           String   @map("event_type") @db.VarChar(100)
  pageUrl             String?  @map("page_url") @db.VarChar(1000)
  pageTitle           String?  @map("page_title") @db.VarChar(500)
  resourceId          String?  @map("resource_id") @db.Uuid
  timeOnPageSeconds   Int?     @map("time_on_page_seconds")
  scoreContribution   Int?     @map("score_contribution") @db.SmallInt
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  visitor SiteVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  @@index([visitorId])
  @@index([eventType])
  @@index([createdAt])
  @@map("visitor_events")
}

model Enquiry {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitorId            String?          @map("visitor_id") @db.Uuid
  firstName            String           @map("first_name") @db.VarChar(100)
  lastName             String           @map("last_name") @db.VarChar(100)
  email                String           @db.VarChar(255)
  phone                String?          @db.VarChar(50)
  companyName          String?          @map("company_name") @db.VarChar(255)
  companySize          String?          @map("company_size") @db.VarChar(50)
  websiteUrl           String?          @map("website_url") @db.VarChar(500)
  serviceInterest      Json?            @map("service_interest")
  budgetRange          String?          @map("budget_range") @db.VarChar(100)
  timeline             String?          @db.VarChar(100)
  message              String?          @db.Text
  source               String?          @db.VarChar(50)
  leadScore            Int?             @map("lead_score") @db.SmallInt
  leadTemperature      LeadTemperature? @map("lead_temperature")
  status               EnquiryStatus    @default(new)
  assignedTo           String?          @map("assigned_to") @db.Uuid
  convertedToClientId  String?          @map("converted_to_client_id") @db.Uuid
  recaptchaScore       Decimal?         @map("recaptcha_score") @db.Decimal(3, 2)
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  assignedStaff    User?                  @relation("AssignedEnquiries", fields: [assignedTo], references: [id])
  convertedClient  User?                  @relation("ConvertedEnquiries", fields: [convertedToClientId], references: [id])
  leadScore_       EnquiryLeadScore?
  notes            EnquiryNote[]
  statusHistory    EnquiryStatusHistory[]
  chatbotSession   ChatbotSession?
  dripQueue        EmailDripQueue[]
  dripLog          EmailDripLog[]
  siteVisitors     SiteVisitor[]
  @@index([status])
  @@index([leadTemperature])
  @@index([assignedTo])
  @@index([leadScore(sort: Desc)])
  @@map("enquiries")
}

model EnquiryLeadScore {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enquiryId      String   @unique @map("enquiry_id") @db.Uuid
  behaviourScore Int      @map("behaviour_score") @db.SmallInt
  formScore      Int      @map("form_score") @db.SmallInt
  totalScore     Int      @map("total_score") @db.SmallInt
  scoreBreakdown Json     @map("score_breakdown")
  calculatedAt   DateTime @default(now()) @map("calculated_at") @db.Timestamptz
  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  @@map("enquiry_lead_scores")
}

model LeadScoreFactor {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  factorKey    String        @unique @map("factor_key") @db.VarChar(100)
  factorLabel  String        @map("factor_label") @db.VarChar(200)
  category     ScoreCategory
  maxPoints    Int           @map("max_points") @db.SmallInt
  isActive     Boolean       @default(true) @map("is_active")
  @@map("lead_score_factors")
}

model EnquiryNote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enquiryId  String   @map("enquiry_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  noteText   String   @map("note_text") @db.Text
